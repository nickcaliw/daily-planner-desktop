{
  "name": "daily-planner-desktop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port 5173",
    "electron": "electron .",
    "dev:all": "concurrently \"npm run dev\" \"sleep 2 && npm run electron\"",
    "build:vite": "vite build",
    "build:electron": "electron-builder --mac",
    "build:app": "npm run build:vite && npm run build:electron",
    "build": "vite build",
    "package": "npm run build && electron-builder --mac",
    "lint": "eslint ."
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.2.4"
  },
  "build": {
    "appId": "com.dailyplanner.app",
    "productName": "Daily Planner",
    "mac": {
      "target": ["dir", "zip"],
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "asar": true
  }
}
